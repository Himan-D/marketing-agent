# Database
DATABASE_URL=postgresql+asyncpg://agent:agent@localhost:5432/marketing

# Redis
REDIS_URL=redis://localhost:6379

# Twenty CRM (self-hosted)
TWENTY_BASE_URL=http://localhost:3000/rest
TWENTY_API_KEY=your-twenty-api-key-here

# Local vLLM (OpenAI-compatible)
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Apollo.io
APOLLO_API_KEY=your-apollo-api-key

# Apify
APIFY_API_TOKEN=your-apify-token

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Your Name <your-email@gmail.com>"

# Rate limits
EMAIL_MAX_PER_HOUR=50
EMAIL_MIN_DELAY_SECONDS=180
EMAIL_DAILY_CAP=200
